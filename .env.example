# LLM API (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o

# Embedding API (optional, falls back to local hash embedding)
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small

# Data directory (defaults to userData)
# AGENT_DATA_DIR=

# 任务失败重规划最大次数（默认 5）
MAX_RETRY_ATTEMPTS=5

# MCP Server 配置（二选一）
# 方式1: JSON 字符串
# MCP_SERVERS=[{"name":"filesystem","transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","D:\\"]}]

# 方式2: 配置文件路径（推荐）
MCP_SERVERS_CONFIG=./mcp-servers.json

# 项目根目录（AGENTS.md / feature_list.json / progress.md 所在位置）
PROJECT_ROOT=.

# Windows 若 preload 加载失败可取消注释
# NO_SANDBOX=1

# 本地文件工具
# READ_FILE_MAX_CHARS=100000

# 网络搜索（web_search 真实 API）
# provider: tavily | brave | serpapi | duckduckgo（未配置 Key 时默认 duckduckgo，无需 Key）
# WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
# BRAVE_SEARCH_API_KEY=
# SERPAPI_API_KEY=
